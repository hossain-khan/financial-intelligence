{
  "name": "financial-intelligence",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "pnpm --filter @financial-intelligence/web dev",
    "build": "pnpm -r --if-present build",
    "browser:test": "playwright test",
    "browser:test:chromium": "playwright test --project=chromium",
    "typecheck": "pnpm -r --if-present typecheck && tsc -p tsconfig.e2e.json",
    "typescript:check": "node scripts/check-typescript-toolchain.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint apps e2e packages scripts playwright.config.ts",
    "format": "prettier --write \"apps/**/*.{ts,tsx,css,html,json,mjs}\" \"e2e/**/*.{ts,tsx}\" \"packages/**/*.{ts,tsx,json,mjs}\" \"scripts/**/*.{js,mjs,ts}\" \"*.{ts,json,mjs,yaml,yml}\"",
    "format:check": "prettier --check \"apps/**/*.{ts,tsx,css,html,json,mjs}\" \"e2e/**/*.{ts,tsx}\" \"packages/**/*.{ts,tsx,json,mjs}\" \"scripts/**/*.{js,mjs,ts}\" \"*.{ts,json,mjs,yaml,yml}\"",
    "schema:check": "pnpm --filter @financial-intelligence/schemas schema:check",
    "schema:generate": "pnpm --filter @financial-intelligence/schemas schema:generate",
    "security:headers:check": "node apps/web/scripts/check-security-headers.mjs",
    "cloudflare:check": "pnpm build && wrangler deploy --dry-run --outdir .wrangler/dry-run",
    "cloudflare:preview": "pnpm build && wrangler dev",
    "cloudflare:deploy": "pnpm build && wrangler deploy"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript/native": "npm:typescript@7.0.2",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "fake-indexeddb": "6.2.5",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "typescript": "npm:@typescript/typescript6@6.0.2",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10",
    "wrangler": "4.112.0"
  }
}
